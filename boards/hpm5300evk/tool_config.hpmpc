        "init_board_clock": {
          "selectClocks": {
            "srcClocks": [],
            "funcClocks": []
          },
          "enableClocks": {
            "clk_top_cpu0": 0,
            "clk_top_ahb0": 0,
            "clk_lmm0": 0,
            "clk_top_mct0": 0,
            "clk_rom": 0,
            "clk_mot0": 0,
            "clk_gpio": 0,
            "clk_hdma": 0,
            "clk_top_xpi0": 0,
            "clk_ptpc": 0
          }
        },
        "init_board_clock_source": {
          "selectClocks": {
            "srcClocks": [
              "clk0_pll0",
              "clk1_pll0",
              "clk2_pll0"
            ],
            "funcClocks": [
              "clk_top_mct0"
            ]
          },
          "enableClocks": {},
          "funcClkConfig": {
            "clk_top_mct0": {
              "from": "osc24m",
              "divFactor": 1
            }
          },
          "pllClkConfig": {
            "pll0": {
              "params": {
                "mfd": 240000000,
                "mfi": 40,
                "mfn": 0,
                "frequency": 960000000
              }
            }
