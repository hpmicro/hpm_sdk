    "clock": {
      "functions": {
        "init_acmp0_clock": {
          "selectClocks": {
            "srcClocks": [],
            "funcClocks": []
          },
          "enableClocks": {
            "clk_acmp0": 0
          }
        },
        "init_adc0_analog_clock": {
          "selectClocks": {
            "srcClocks": [
              "osc32k",
              "osc24m"
            ],
            "funcClocks": [
              "clk_top_adc0"
            ],
            "pllVcoClocks": []
          },
          "enableClocks": {
            "clk_top_adc0": "0"
          },
          "funcClkConfig": {
            "clk_top_adc0": {
              "from": "clk_top_ana0"
            },
            "clk_top_ana0": {
              "from": "clk2_pll0",
              "divFactor": 2
            }
          }
        },
        "init_adc0_bus_clock": {
          "selectClocks": {
            "srcClocks": [
